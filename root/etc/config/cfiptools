config cfiptools 'config'
	option enabled '1'
	option cron_schedule '*/30 * * * *'
	option input_url 'https://zip.cm.edu.kg/all.txt'
	option download_input '1'
	option download_timeout '30'
	option input_file '/usr/share/cfiptools/ips.txt'
	option full_output_file '/usr/share/cfiptools/full_ips.txt'
	option best_output_file '/usr/share/cfiptools/best_ips.txt'
	option tcp_timeout_ms '500'
	option tcp_workers '200'
	option speed_timeout_sec '6'
	option speed_workers '5'
	option min_speed_mbps '16'
	option top_per_region '10'
	option show_latency '1'
	option show_bandwidth '1'
	option numbered_regions '1'
	option fast_label '优选高速'
	option update_readme '0'
	option bypass_proxy_method 'nftables'
	option last_run ''
	option last_result ''